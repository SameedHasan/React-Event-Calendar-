{
  "name": "react-event-calendar-suite",
  "private": false,
  "version": "1.3.0",
  "description": "A premium, highly performant, and fully customizable React Event Calendar component suite.",
  "keywords": [
    "react",
    "calendar",
    "event",
    "event-calendar",
    "react-calendar",
    "agenda",
    "scheduler",
    "ics-export",
    "ical",
    "month-view",
    "week-view",
    "day-view",
    "year-view"
  ],
  "author": "Sameed Hasan",
  "license": "MIT",
  "homepage": "https://github.com/SameedHasan/React-Event-Calendar-#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SameedHasan/React-Event-Calendar-.git"
  },
  "bugs": {
    "url": "https://github.com/SameedHasan/React-Event-Calendar-/issues"
  },
  "type": "module",
  "main": "./dist/react-event-calendar-suite.umd.cjs",
  "module": "./dist/react-event-calendar-suite.js",
  "types": "./types/index.d.ts",
  "style": "./dist/react-event-calendar-suite.css",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/react-event-calendar-suite.js",
      "require": "./dist/react-event-calendar-suite.umd.cjs"
    },
    "./utils/icsExport": {
      "types": "./types/utils/icsExport.d.ts",
      "import": "./dist/utils/icsExport.js",
      "require": "./dist/utils/icsExport.cjs"
    },
    "./dist/react-event-calendar-suite.css": "./dist/react-event-calendar-suite.css",
    "./style.css": "./dist/react-event-calendar-suite.css"
  },
  "files": [
    "dist",
    "types",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --config vite.ics.config.js",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "npm run build && npm run lint && npm run test",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "@ant-design/icons": "^5.0.0",
    "antd": "^5.0.0",
    "dayjs": "^1.11.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@ant-design/icons": "^5.6.1",
    "@eslint/js": "^9.36.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.3",
    "antd": "^5.27.4",
    "dayjs": "^1.11.13",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "vite": "^7.1.7",
    "vitest": "^3.2.4",
    "zustand": "^5.0.8"
  }
}
