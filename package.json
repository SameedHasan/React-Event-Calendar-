{
  "name": "react-event-calendar-suite",
  "private": false,
  "version": "3.0.0",
  "description": "Framework-agnostic React event calendar & scheduler — no UI-library dependency, drops into MUI, antd, Tailwind, Bootstrap or custom CSS. Month/week/day/list/year views, drag-and-drop, recurring events (RRULE), i18n, timezone, ICS import & export. TypeScript, React 18/19, Vite & Next.js.",
  "keywords": [
    "react",
    "react-calendar",
    "react-event-calendar",
    "event-calendar",
    "calendar",
    "calendar-component",
    "scheduler",
    "react-scheduler",
    "appointment-calendar",
    "booking-calendar",
    "agenda",
    "event",
    "event-scheduler",
    "fullcalendar-alternative",
    "month-view",
    "week-view",
    "day-view",
    "list-view",
    "year-view",
    "time-grid",
    "drag-and-drop",
    "dnd",
    "recurring-events",
    "rrule",
    "ics-export",
    "ics-import",
    "ical",
    "icalendar",
    "timezone",
    "i18n",
    "localization",
    "typescript",
    "antd",
    "ant-design",
    "nextjs",
    "vite",
    "accessibility",
    "a11y",
    "ui-component",
    "component-library",
    "framework-agnostic",
    "no-dependency",
    "material-ui-compatible",
    "tailwind-compatible"
  ],
  "author": "Sameed Hasan (https://github.com/SameedHasan)",
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "homepage": "https://sameedhasan.github.io/React-Event-Calendar/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SameedHasan/React-Event-Calendar.git"
  },
  "bugs": {
    "url": "https://github.com/SameedHasan/React-Event-Calendar/issues"
  },
  "type": "module",
  "main": "./dist/react-event-calendar-suite.umd.cjs",
  "module": "./dist/react-event-calendar-suite.js",
  "types": "./types/index.d.ts",
  "style": "./dist/react-event-calendar-suite.css",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/react-event-calendar-suite.js",
      "require": "./dist/react-event-calendar-suite.umd.cjs"
    },
    "./utils/icsExport": {
      "types": "./types/utils/icsExport.d.ts",
      "import": "./dist/utils/icsExport.js",
      "require": "./dist/utils/icsExport.cjs"
    },
    "./utils/icsImport": {
      "types": "./types/utils/icsImport.d.ts",
      "import": "./dist/utils/icsImport.js",
      "require": "./dist/utils/icsImport.cjs"
    },
    "./dist/react-event-calendar-suite.css": "./dist/react-event-calendar-suite.css",
    "./style.css": "./dist/react-event-calendar-suite.css"
  },
  "files": [
    "dist",
    "types",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --config vite.ics.config.js",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci": "npm run build && npm run lint && npm run test && npm run build-storybook",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static"
  },
  "peerDependencies": {
    "dayjs": "^1.11.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@storybook/addon-docs": "^9.1.20",
    "@storybook/addon-links": "^9.1.20",
    "@storybook/react-vite": "^9.1.20",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "dayjs": "^1.11.13",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "jsdom": "^29.1.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "storybook": "^9.1.20",
    "vite": "^7.1.7",
    "vitest": "^3.2.4",
    "zustand": "^5.0.8"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "react-datepicker": "^9.1.0",
    "rrule": "^2.8.1"
  }
}
